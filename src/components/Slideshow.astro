---
const slides = [
  "https://staratakashta-bg.com/modules/mod_btslideshow/images/98/slideshow/starata-kashta-pic-2.jpg",
  "https://staratakashta-bg.com/modules/mod_btslideshow/images/98/slideshow/starata-kashta-pic-1.jpg", // Add more image URLs here
];
---

<div
  class="relative w-full h-[300px] md:h-full min-h-[320px] overflow-hidden rounded shadow-lg border border-stone-200/40"
  id="slideshow-container"
>
  {
    slides.map((src, index) => (
      <div
        class={`absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? "opacity-100" : "opacity-0"}`}
        data-slide-index={index}
      >
        <img
          src={src}
          alt="Снимка от градината на Старата къща"
          class="w-full h-full object-cover"
          loading={index === 0 ? "eager" : "lazy"}
        />
      </div>
    ))
  }

  <!-- Subtle dark overlay on bottom for depth -->
  <div
    class="absolute bottom-0 inset-x-0 h-1/4 bg-gradient-to-t from-black/50 to-transparent pointer-events-none"
  >
  </div>
</div>

<script>
  const slides = document.querySelectorAll("#slideshow-container [data-slide-index]");
  let current = 0;

  if (slides.length > 1) {
    setInterval(() => {
      slides[current].classList.remove("opacity-100");
      slides[current].classList.add("opacity-0");

      current = (current + 1) % slides.length;

      slides[current].classList.remove("opacity-0");
      slides[current].classList.add("opacity-100");
    }, 5000); // Transitions every 5 seconds
  }
</script>
