---
import { BASE_URL } from "../utils/constants.ts";

const currentPath = Astro.url.pathname;

const navItems = [
  { href: `${BASE_URL}`, label: "Начало" },
  { href: `${BASE_URL}menu`, label: "Меню" },
  { href: `${BASE_URL}gallery`, label: "Галерия" },
  { href: `${BASE_URL}contacts`, label: "Контакти" },
];

// Helper function to strip trailing slashes for reliable matching
const normalize = (path: string) => path.replace(/\/$/, "");
---

<header
  class="sticky top-0 z-40 w-full py-4 px-4 md:px-8 max-w-6xl mx-auto mb-4 bg-woven-texture opacity-95 backdrop-blur-sm rounded-b-md"
>
  <div class="flex flex-row justify-between items-center pb-2 gap-2">
    <!-- Logo with authentic traditional title styling -->
    <a href=`${BASE_URL}` class="text-center md:text-left">
      <img src={`${BASE_URL}images/logo.png`} alt="Лого" />
    </a>

    <!-- Navigation Bar -->
    <nav aria-label="Основна навигация">
      <!-- Mobile menu toggle (opens the sidebar) -->
      <button
        id="mobile-nav-toggle"
        class="md:hidden flex items-center px-4 py-2 border border-white/20 rounded text-stone-200 hover:text-white"
        aria-expanded="false"
        aria-controls="mobile-nav-sidebar"
      >
        <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20"
          ><path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"></path></svg
        >
      </button>

      <!-- Desktop Nav Links -->
      <ul class="hidden md:flex flex-row items-center gap-8">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class={`text-sm tracking-widest uppercase transition-all duration-200 py-2 px-1 block ${
                  normalize(currentPath) === normalize(item.href)
                    ? "text-amber-400 font-semibold border-b-2 border-amber-500"
                    : "text-stone-200 hover:text-amber-400"
                }`}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<!-- Mobile sidebar: backdrop -->
<div
  id="mobile-nav-backdrop"
  class="mobile-nav-backdrop fixed inset-0 bg-black/60 z-40 opacity-0 pointer-events-none md:hidden"
  aria-hidden="true"
>
</div>

<!-- Mobile sidebar: sliding panel -->
<aside
  id="mobile-nav-sidebar"
  class="mobile-nav-sidebar fixed top-0 left-0 h-full w-80 max-w-[85%] bg-[#2a0101] border-r border-[#3d1a1a] z-50 flex flex-col justify-between p-6 md:hidden shadow-2xl"
  aria-label="Мобилна навигация"
>
  <div>
    <!-- Top Header inside Drawer -->
    <div class="flex items-center justify-between pb-6 border-b border-white/10 mb-6">
      <div class="flex flex-col">
        <a href=`${BASE_URL}` class="w-45">
          <img src={`${BASE_URL}images/logo.png`} alt="Лого" />
        </a>
      </div>
      <button
        id="mobile-nav-close"
        class="text-stone-300 hover:text-amber-400 p-2"
        aria-label="Затвори навигацията"
      >
        <svg class="h-6 w-6 fill-current" viewBox="0 0 20 20">
          <path
            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Navigation Links -->
    <ul class="flex flex-col gap-2">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`text-sm tracking-widest uppercase transition-colors duration-200 py-3 px-4 rounded-lg block ${
                normalize(currentPath) === normalize(item.href)
                  ? "text-amber-400 font-bold bg-white/10"
                  : "text-stone-200 hover:text-amber-400 hover:bg-white/5"
              }`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Bottom Drawer Actions (Direct Contact Info for Phone Users) -->
  <div class="flex justify-center gap-2 pt-6 border-t border-white/10 space-y-4">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="1em"
      height="1em"
      viewBox="0 0 24 24"
      class="text-stone-400"
      fill="currentColor"
    >
      <path d="M0 0h24v24H0z" fill="none"></path>
      <path fill="currentColor" d="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2z"></path>
    </svg>
    <p class="text-[11px] text-stone-400 text-center font-light">кв. Редута, ул. Марагидик 21</p>
  </div>
</aside>

<style>
  /* Off-canvas sidebar: hidden off the left edge by default, slides in when open. */
  .mobile-nav-sidebar {
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  .mobile-nav-sidebar.is-open {
    transform: translateX(0);
  }

  .mobile-nav-backdrop {
    transition: opacity 0.3s ease;
  }

  .mobile-nav-backdrop.is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const closeBtn = document.getElementById("mobile-nav-close");
  const sidebar = document.getElementById("mobile-nav-sidebar");
  const backdrop = document.getElementById("mobile-nav-backdrop");

  function openNav() {
    sidebar?.classList.add("is-open");
    backdrop?.classList.add("is-open");
    toggle?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeNav() {
    sidebar?.classList.remove("is-open");
    backdrop?.classList.remove("is-open");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openNav);
  closeBtn?.addEventListener("click", closeNav);
  backdrop?.addEventListener("click", closeNav);

  // Close on Escape for accessibility
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeNav();
  });

  // Close the sidebar when a link inside it is clicked (in case of client-side routing)
  sidebar?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeNav);
  });
</script>
