---
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.astro";
import "../styles/global.css";
import { BASE_URL } from "../utils/constants";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Ресторант-градина Старата къща в кв. Редута, София. Традиционна българска кухня, ретро музика и прохладна градина под сянката на 30-годишна лоза.",
  ogImage = "/images/gallery/IMG_6795.webp",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://staratakashta-bg.com");

// IMPORTANT: resolve the OG image against the SITE ROOT (Astro.site), not
// against canonicalURL. canonicalURL already includes the page's own path
// (and, on GitHub Pages, the /restaurant-starata-kashta/ base prefix), so
// resolving a relative ogImage path against it was silently producing wrong
// URLs depending on which page rendered the tag. Astro.site is the one
// stable root every image path should be resolved from.
const siteRoot = Astro.site || new URL("https://staratakashta-bg.com");
const ogImageURL = new URL(ogImage, siteRoot);
---

<!doctype html>
<html lang="bg" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href=`${BASE_URL}favicon.svg` />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta
      name="keywords"
      content="ресторант, механа, българска кухня, ястия, гозби, специалитети, традиционно, битов, стил, мероприятие,  тържество, частно парти, ретро музика, уют, градина, лоза, асма, редута"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={`${title} — Ресторант Старата къща`} />
    <meta property="og:locale" content="bg_BG" />
    <meta property="og:site_name" content="Ресторант Старата къща" />

    <!-- Twitter/X card (falls back to the same OG image/description) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,100..900;1,100..900&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org Local Business Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Restaurant",
        "@id": "https://staratakashta-bg.com",
        "name": "Ресторант Старата къща",
        "image": "https://staratakashta-bg.com/images/gallery/IMG_6795.webp",
        "url": "https://staratakashta-bg.com",
        "telephone": ["+359893805905", "+359886805905", "+359878805905"],
        "priceRange": "$$",
        "servesCuisine": "Българска кухня",
        "hasMenu": "https://staratakashta-bg.com/menu",
        "sameAs": ["https://www.facebook.com/profile.php?id=100000464105093"],
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "ул. Марагидик 21, кв. Редута",
          "addressLocality": "София",
          "postalCode": "1505",
          "addressCountry": "BG"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "42.693596",
          "longitude": "23.357010"
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "11:30",
          "closes": "22:30"
        }
      }
    </script>
  </head>
  <body
    class="bg-woven-texture text-stone-800 font-sans antialiased flex flex-col min-h-screen relative"
  >
    <!-- Sophisticated background pattern mimicking traditional damask fabric texture -->
    <div class="absolute inset-0 bg-repeat opacity-[0.03] pointer-events-none z-0"></div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <Navigation />
      <slot />
      <Footer />
    </div>
  </body>
</html>
