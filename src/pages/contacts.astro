---
import Layout from "../layouts/Layout.astro";
import { CONTACT_INFO } from "../utils/constants.ts";

const { phoneNumbers, facebookUrl, address, mapsUrl, embedMapsUrl } = CONTACT_INFO;
---

<Layout
  title="Контакти - Ресторант Старата къща"
  description="Резервирайте маса в ресторант Старата къща на тел. 0893 805 905. Намираме се в кв. Редута, ул. Марагидик 21, София."
>
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 mb-8 grow">
    <section
      class="bg-parchment rounded-2xl shadow-2xl p-6 sm:p-10 md:p-12 mb-12 relative overflow-hidden"
    >
      <!-- Decorative top crimson-to-gold accent line -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-burgundy-deep via-burgundy-brand to-gold-amber"
      >
      </div>

      <!-- Header Section -->
      <header class="text-center max-w-2xl mx-auto mb-8 pb-6 border-b border-parchment-border">
        <span
          class="text-sm md:text-base font-semibold tracking-wider text-burgundy-brand mb-2 block"
        >
          Запитвания & Резервации
        </span>
        <h1
          class="text-3xl sm:text-4xl md:text-5xl tracking-tight font-serif text-burgundy-deep font-bold uppercase mb-4"
        >
          Контакти
        </h1>
        <p class="text-stone-600 text-sm md:text-base leading-relaxed font-light">
          Пишете ни през формата за обратна връзка или се свържете директно с нас на посочените
          телефони.
        </p>
      </header>

      <!-- Main Section Container -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Left Column: Contact Form -->
        <div
          class="lg:col-span-7 bg-white/40 p-6 rounded-2xl border border-parchment-border/50 shadow-xs"
        >
          <form id="contact-form" class="space-y-4" novalidate>
            <!-- Honeypot spam trap -->
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="mb-4">
              <label for="name" class="block text-xs font-bold uppercase text-stone-700 mb-2">
                Вашето Име <span class="text-burgundy-brand font-serif">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="Име"
                required
                class="w-full bg-white/90 border border-parchment-border rounded-lg p-4 text-sm text-stone-800 placeholder-stone-400 outline-none focus:border-burgundy-brand focus:bg-white focus:ring-2 focus:ring-burgundy-brand/15 transition-all duration-200 shadow-2xs"
                placeholder="Иван Иванов"
              />
            </div>

            <div class="mb-4">
              <label for="email" class="block text-xs font-bold uppercase text-stone-700 mb-2">
                Е-мейл адрес <span class="text-burgundy-brand font-serif">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="Имейл"
                required
                class="w-full bg-white/90 border border-parchment-border rounded-lg p-4 text-sm text-stone-800 placeholder-stone-400 outline-none focus:border-burgundy-brand focus:bg-white focus:ring-2 focus:ring-burgundy-brand/15 transition-all duration-200 shadow-2xs"
                placeholder="example@mail.com"
              />
            </div>

            <div class="mb-4">
              <label for="topic" class="block text-xs font-bold uppercase text-stone-700 mb-2">
                Тема на съобщението <span class="text-burgundy-brand font-serif">*</span>
              </label>
              <input
                type="text"
                id="topic"
                name="Тема"
                required
                class="w-full bg-white/90 border border-parchment-border rounded-lg p-4 text-sm text-stone-800 placeholder-stone-400 outline-none focus:border-burgundy-brand focus:bg-white focus:ring-2 focus:ring-burgundy-brand/15 transition-all duration-200 shadow-2xs"
                placeholder="Резервация на събитие / Друго"
              />
            </div>

            <div class="mb-4">
              <label for="message" class="block text-xs font-bold uppercase text-stone-700 mb-2">
                Съобщение <span class="text-burgundy-brand font-serif">*</span>
              </label>
              <textarea
                id="message"
                name="Съобщение"
                rows="5"
                required
                class="w-full bg-white/90 border border-parchment-border rounded-lg p-4 text-sm text-stone-800 placeholder-stone-400 outline-none focus:border-burgundy-brand focus:bg-white focus:ring-2 focus:ring-burgundy-brand/15 transition-all duration-200 resize-y shadow-2xs"
                placeholder="Напишете вашето запитване тук..."></textarea>
            </div>

            <!-- Submit Button (Integrated with Unified Primary Style) -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full sm:w-auto btn-primary cursor-pointer text-center"
            >
              <svg
                class="w-6 h-6 fill-current text-white shrink-0"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"
                ></path>
              </svg>
              <span id="submit-label" class="tracking-wider">Изпрати съобщение</span>
            </button>

            <!-- Status feedback -->
            <p id="form-status" class="text-sm hidden" role="status" aria-live="polite"></p>
          </form>
        </div>

        <!-- Right Column: Sidebar Info & Map -->
        <div class="lg:col-span-5 space-y-6">
          <div
            class="bg-parchment-dark/40 p-6 rounded-2xl border border-parchment-border/60 shadow-inner"
          >
            <!-- Address Section -->
            <h2 class="font-bold uppercase text-burgundy-brand mb-2 flex items-center gap-2">
              <svg
                class="w-4 h-4 text-burgundy-brand fill-current shrink-0"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                  clip-rule="evenodd"></path>
              </svg>
              Адрес
            </h2>
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-stone-800 hover:text-burgundy-brand leading-relaxed block mb-4 hover:underline"
            >
              {address}
            </a>

            <!-- Phones Section -->
            <h2 class="font-bold uppercase text-burgundy-brand mb-2 flex items-center gap-2">
              <svg
                class="w-4 h-4 text-burgundy-brand fill-current shrink-0"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                ></path>
              </svg>
              Телефони за резервация
            </h2>
            <ul class="space-y-2 mb-4">
              {
                phoneNumbers.map((number) => (
                  <li>
                    <a
                      href={`tel:${number.replace(/\s/g, "")}`}
                      class="text-sm font-mono text-stone-800 hover:text-burgundy-brand transition-colors flex items-center gap-2"
                    >
                      {number}
                    </a>
                  </li>
                ))
              }
            </ul>

            <!-- Redesigned Tavern-cohesive Facebook button -->
            <a
              href={facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full inline-flex items-center justify-center gap-2 bg-burgundy-deep hover:bg-burgundy-brand border border-parchment-border text-xs font-bold tracking-widest uppercase p-3.5 rounded-lg text-white shadow-md transition-all duration-200"
            >
              <svg
                class="w-6 h-6 fill-current text-white shrink-0"
                viewBox="0 0 24 24"
                aria-hidden="true"
                ><path
                  d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                ></path></svg
              >
              Facebook страница
            </a>
          </div>

          <!-- Rounded, cohesive Google Map Frame -->
          <div
            class="rounded-2xl overflow-hidden shadow-md h-64 md:h-72 border border-parchment-border"
          >
            <iframe
              title="Карта с местоположението на ресторант Старата къща"
              src={embedMapsUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full border-0 block"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const WEB3FORMS_ACCESS_KEY = "1018cf8d-3aa9-489f-9eed-c74492ea5bdf";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitLabel = document.getElementById("submit-label") as HTMLElement;
  const status = document.getElementById("form-status") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = "Изпращане...";
    status.classList.add("hidden");

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);

    Object.assign(object, {
      access_key: WEB3FORMS_ACCESS_KEY,
      subject: "Ново съобщение от контактна форма",
      from_name: "Старата къща - контактна форма",
    });

    const json = JSON.stringify(object);

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json; charset=UTF-8",
          Accept: "application/json",
        },
        body: json,
      });
      const result = await response.json();

      if (result.success) {
        status.textContent = "Съобщението е изпратено успешно! Ще се свържем с вас скоро.";
        status.className = "text-sm text-green-700 font-medium mt-3";
        form.reset();
      } else {
        throw new Error(result.message || "Unknown error");
      }
    } catch (err) {
      status.textContent =
        "Възникна грешка при изпращането. Моля, опитайте отново или ни се обадете.";
      status.className = "text-sm text-burgundy-brand font-medium mt-3";
    } finally {
      submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = "Изпрати съобщение";
      status.classList.remove("hidden");
    }
  });
</script>
