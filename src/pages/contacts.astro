---
import Layout from "../layouts/Layout.astro";
import { CONTACT_INFO } from "../utils/constants.ts";

const { phoneNumbers, facebookUrl, address, mapsUrl, embedMapsUrl } = CONTACT_INFO;
---

<Layout
  title="Контакти - Ресторант Старата къща"
  description="Резервирайте маса в ресторант Старата къща на тел. 0893 805 905. Намираме се в кв. Редута, ул. Марагидик 21, София."
>
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 py-10 md:py-16 grow">
    <section class="bg-[#faf7f0] rounded-md p-6 sm:p-10 md:p-16 mb-12 relative overflow-hidden">
      <!-- Decorative top accent bar -->
      <div
        class="absolute top-0 left-0 right-0 h-2 bg-linear-to-r from-[#5c0606] via-[#8c0e0e] to-[#5c0606]"
      >
      </div>

      <!-- Header Section -->
      <header class="text-center max-w-2xl mx-auto mb-4 pb-8 border-b border-stone-200">
        <h1
          class="text-4xl md:text-5xl font-serif text-[#5c0606] font-bold tracking-wide uppercase mb-6"
        >
          Контакти
        </h1>
        <p class="text-stone-700 text-sm md:text-base leading-relaxed font-light">
          Пишете ни, или ни намерете директно - с удоволствие ще отговорим възможно най-скоро.
        </p>
      </header>

      <!-- Main Section Container using Flexbox -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
        <!-- Left Column: Contact Form -->
        <div
          class="lg:col-span-7 bg-white/60 p-6 md:p-8 rounded-xl shadow-sm border border-stone-200/50"
        >
          <form id="contact-form" class="space-y-6" novalidate>
            <!-- Honeypot spam trap -->
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
            />

            <div class="space-y-2">
              <label for="name" class="block text-sm font-semibold text-stone-700">
                Име <span class="text-[#8c0e0e]">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="Име"
                required
                class="w-full bg-white border border-stone-200 rounded-lg px-4 py-3 text-sm text-stone-800 outline-none focus:border-[#8c0e0e] transition-colors duration-200"
              />
            </div>

            <div class="space-y-2">
              <label for="email" class="block text-sm font-semibold text-stone-700">
                Е-мейл <span class="text-[#8c0e0e]">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="Имейл"
                required
                class="w-full bg-white border border-stone-200 rounded-lg px-4 py-3 text-sm text-stone-800 outline-none focus:border-[#8c0e0e] transition-colors duration-200"
              />
            </div>

            <div class="space-y-2">
              <label for="topic" class="block text-sm font-semibold text-stone-700">
                Тема <span class="text-[#8c0e0e]">*</span>
              </label>
              <input
                type="text"
                id="topic"
                name="Тема"
                required
                class="w-full bg-white border border-stone-200 rounded-lg px-4 py-3 text-sm text-stone-800 outline-none focus:border-[#8c0e0e] transition-colors duration-200"
              />
            </div>

            <div class="space-y-2">
              <label for="message" class="block text-sm font-semibold text-stone-700">
                Съобщение <span class="text-[#8c0e0e]">*</span>
              </label>
              <textarea
                id="message"
                name="Съобщение"
                rows="6"
                required
                class="w-full bg-white border border-stone-200 rounded-lg px-4 py-3 text-sm text-stone-800 outline-none focus:border-[#8c0e0e] transition-colors duration-200 resize-y"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full sm:w-auto bg-[#8c0e0e] hover:bg-[#5c0606] text-white text-xs md:text-sm font-bold tracking-wider uppercase px-8 py-4 rounded-lg transition-all duration-200 shadow-md hover:shadow-lg disabled:opacity-60 disabled:cursor-not-allowed text-center cursor-pointer"
            >
              <span id="submit-label">Изпратете съобщение</span>
            </button>

            <!-- Status feedback -->
            <p id="form-status" class="text-sm hidden" role="status" aria-live="polite"></p>
          </form>
        </div>

        <!-- Right Column: Sidebar Info & Map -->
        <div class="lg:col-span-5 space-y-8">
          <div class="bg-stone-100/80 p-6 rounded-xl border border-stone-200/60">
            <h2 class="text-xs font-bold tracking-[0.2em] uppercase text-[#8c0e0e] mb-3">Адрес</h2>
            <a
              href={mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-base text-stone-800 hover:text-[#8c0e0e] leading-relaxed block mb-6 hover:underline"
            >
              {address}
            </a>

            <h2 class="text-xs font-bold tracking-[0.2em] uppercase text-[#8c0e0e] mb-3">
              Телефони за резервация
            </h2>
            <ul class="space-y-2 mb-6">
              {
                phoneNumbers.map((number) => (
                  <li>
                    <a
                      href={`tel:${number.replace(/\s/g, "")}`}
                      class="text-base font-mono font-medium text-stone-800 hover:text-[#8c0e0e]"
                    >
                      {number}
                    </a>
                  </li>
                ))
              }
            </ul>

            <a
              href={facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full inline-flex items-center justify-center gap-3 bg-[#1877f2] hover:bg-[#0d65d9] text-sm text-white font-bold tracking-wider uppercase p-3 rounded-lg shadow transition-colors"
            >
              <svg class="w-5 h-5 fill-white shrink-0" viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                ></path></svg
              >
              Facebook Page
            </a>
          </div>

          <!-- Map container -->
          <div class="rounded-xl overflow-hidden shadow-md h-64 md:h-75 border border-stone-200/60">
            <iframe
              title="Карта с местоположението на Старата къща"
              src={embedMapsUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full border-0 block"
              allowfullscreen></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const WEB3FORMS_ACCESS_KEY = "1018cf8d-3aa9-489f-9eed-c74492ea5bdf";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitLabel = document.getElementById("submit-label") as HTMLElement;
  const status = document.getElementById("form-status") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitLabel.textContent = "Изпращане...";
    status.classList.add("hidden");

    // 1. Gather form fields into a key-value object
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);

    // 2. Attach Web3Forms metadata to the object
    Object.assign(object, {
      access_key: WEB3FORMS_ACCESS_KEY,
      subject: "Ново съобщение от контактна форма",
      from_name: "Старата къща - контактна форма",
    });

    // 3. Serialize object to a JSON string
    const json = JSON.stringify(object);

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json; charset=UTF-8",
          Accept: "application/json",
        },
        body: json,
      });
      const result = await response.json();

      if (result.success) {
        status.textContent = "Съобщението е изпратено успешно! Ще се свържем с вас скоро.";
        status.className = "text-sm text-green-700 font-medium";
        form.reset();
      } else {
        throw new Error(result.message || "Unknown error");
      }
    } catch (err) {
      status.textContent =
        "Възникна грешка при изпращането. Моля, опитайте отново или ни се обадете.";
      status.className = "text-sm text-[#8c0e0e] font-medium";
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = "Изпратете съобщение";
      status.classList.remove("hidden");
    }
  });
</script>
