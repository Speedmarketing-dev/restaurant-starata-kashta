---
import { BASE_URL } from "../../utils/constants.ts";
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const menuEntries = await getCollection("menu");
  return menuEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"menu">;
}

const { entry } = Astro.props;
const { categoryTitle, categoryDate, items } = entry.data;

// Formats a number as "5.90" style (always 2 decimals) regardless of how it's stored in the data file
const fmt = (n: number) => n.toFixed(2);
---

<Layout title={`${categoryTitle} - Ресторант Старата къща`}>
  <main class="max-w-4xl w-full mx-auto px-4 md:px-8 py-10 md:py-14 grow">
    <section
      class="bg-[#faf7f0] rounded-xl shadow-2xl p-6 md:p-12 border border-stone-200/50 mb-12 relative overflow-hidden"
    >
      <!-- Decorative top accent bar, matching the menu overview page -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-[#5c0606] via-[#8c0e0e] to-[#5c0606]"
      >
      </div>

      <!-- Back link -->
      <a
        href=`${BASE_URL}menu`
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-[#8c0e0e] hover:text-[#5c0606] transition-colors duration-200 mb-8"
      >
        <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
          <path
            d="M12.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L8.414 10l4.293 4.293a1 1 0 010 1.414z"
          ></path>
        </svg>
        Обратно към менюто
      </a>

      <header class="text-center mb-8 pb-8 border-b border-stone-200/70">
        <h1
          class="text-3xl md:text-5xl font-serif text-[#5c0606] font-bold tracking-wide uppercase"
        >
          {categoryTitle}
        </h1>
        {
          categoryDate && (
            <p class="text-xs md:text-sm text-stone-700 mt-3 tracking-wide">{categoryDate}</p>
          )
        }
      </header>

      <!-- Conditional Item List -->
      {
        items && items.length > 0 ? (
          <ul class="divide-y divide-stone-200/70">
            {items.map((item) => (
              <>
                {item.subheading && (
                  <li class="pt-16 pb-2 first:pt-0" aria-hidden="true">
                    <p class="text-xs text-center md:text-sm font-semibold tracking-[0.2em] uppercase text-[#8c0e0e]">
                      {item.subheading}
                    </p>
                  </li>
                )}
                <li class="menu-item group flex items-start justify-between gap-4 py-4 md:py-5 px-2 md:px-3 rounded-md transition-colors duration-200">
                  <div class="flex-1 min-w-0">
                    <p class="font-serif text-base md:text-lg text-stone-800 font-semibold leading-snug">
                      {item.name}
                      {item.note && (
                        <span class="block mt-1 w-fit align-middle text-[10px] font-sans font-semibold uppercase tracking-wide text-[#8c0e0e] bg-[#8c0e0e]/10 rounded-md px-2 py-0.5">
                          {item.note}
                        </span>
                      )}
                    </p>
                    {item.weight && (
                      <p class="text-xs md:text-sm text-stone-700 mt-1">{item.weight}</p>
                    )}
                  </div>

                  <div class="text-right shrink-0 pt-0.5">
                    {item.priceEur !== undefined && item.priceEur !== null && (
                      <p class="font-serif text-base md:text-lg font-bold text-[#8c0e0e] whitespace-nowrap">
                        {fmt(item.priceEur)}&nbsp;€
                      </p>
                    )}

                    {item.priceBgn !== undefined && item.priceBgn !== null && (
                      <p class="text-xs md:text-sm text-stone-700 whitespace-nowrap">
                        {fmt(item.priceBgn)}&nbsp;лв.
                      </p>
                    )}
                  </div>
                </li>
              </>
            ))}
          </ul>
        ) : (
          /* Friendly Fallback State for empty or omitted categories */
          <div class="flex flex-col items-center gap-8 py-16 px-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="10em"
              height="10em"
              viewBox="0 0 64 64"
              aria-hidden="true"
            >
              <path d="M0 0h64v64H0z" fill="none" />
              <g fill="#3e4347">
                <circle cx="32" cy="32" r="30" />
                <path d="m6.3 18l-2.7-2.7c-2.1-2.1-2.1-5.5 0-7.5l4.2-4.2c2.1-2.1 5.5-2.1 7.5 0L18 6.3l-3.1 3.1l-2.7-2.7c-.3-.3-.9-.3-1.3 0l-4.2 4.2c-.3.3-.3.9 0 1.3l2.7 2.7zm51.4 28l2.7 2.7c2.1 2.1 2.1 5.5 0 7.5l-4.2 4.2c-2.1 2.1-5.5 2.1-7.5 0L46 57.7l3.1-3.1l2.7 2.7c.3.3.9.3 1.3 0l4.2-4.2c.3-.3.3-.9 0-1.3l-2.7-2.7z" />
              </g>
              <circle cx="32" cy="32" r="23.4" fill="#f2b200" />
              <path
                fill="#b47d56"
                d="M39.6 11.4c-5-2.6-12.9 2.4-12 6.6s11.2 7.2 14 13.1s4.1 7.8 9.1 3.8c4.9-4.1 7.2-13.8-11.1-23.5"
              />
              <path
                fill="#89664c"
                d="M38.8 13.8c3.4 0-2.1 1.9-5.3 4.7c-1.6 1.4-.9-4.7 5.3-4.7m7.3 4.9c3.4 0-2.1 1.9-5.4 4.7c-1.5 1.3-.8-4.7 5.4-4.7m4.5 7.5c3.4 0-2.1 1.9-5.4 4.7c-1.5 1.3-.7-4.7 5.4-4.7"
              />
              <path
                fill="#b47d56"
                d="M10.7 38c-1.9-4.8 4.4-10.7 8.5-9.2c4.2 1.5 5.7 10.9 11.2 14.4c5.5 3.4 7.3 4.9 2.5 8.5C28 55.3 17.8 55.5 10.7 38"
              />
              <path
                fill="#89664c"
                d="M13.4 39.3c-.5 2.9 2.2-1.5 5.6-3.8c1.6-1.1-4.7-1.5-5.6 3.8m3.4 6.1c-.5 2.9 2.2-1.5 5.6-3.8c1.6-1.1-4.7-1.5-5.6 3.8m6 4.5c-.5 2.9 2.2-1.5 5.6-3.8c1.6-1.1-4.6-1.6-5.6 3.8"
              />
              <path
                fill="#699635"
                d="M25.6 13c-2.2-2.1-2.2-2.1-8.6 4.6c-3.5 3.7-5.3 7.6-4.1 8.7c2.2 2.1 2.2 2.1 8.5-4.6c3.6-3.6 5.4-7.5 4.2-8.7m25.9 27.2c-1.8-2.4-1.8-2.4-9.1 2.8c-4.1 2.9-6.5 6.3-5.6 7.6c1.8 2.4 1.8 2.4 9.1-2.8c4.1-2.9 6.6-6.3 5.6-7.6m-12.9-7c1.3-3 1.3-3-7.5-7.1c-4.9-2.3-9.4-2.8-10.1-1.2c-1.3 3-1.3 3 7.5 7.1c4.8 2.3 9.3 2.8 10.1 1.2"
              />
              <path
                fill="#ed4c5c"
                d="M43.5 37.8c.2-2.2-1.6-1.1-4.9-1.2c-3.3-.2-2.4 2.4-2.2 4.5c.1 2.1 1.4.4 6.2.5c1.8.1.6-1.6.9-3.8"
              />
              <path
                fill="#ffce31"
                d="M29.9 34.1c-2.5-.9-1.7.8-3 3.2s2.1 2.5 4.6 3.1s.9-.9 2.6-4.4c.7-1.3-1.7-1-4.2-1.9"
              />
              <path
                fill="#ed4c5c"
                d="M24.5 18.9c-2.5-.9-1.7.8-3 3.2s2.1 2.5 4.6 3.1s.9-.9 2.6-4.4c.7-1.3-1.7-1-4.2-1.9"
              />
              <path
                fill="#ffce31"
                d="M14 26.2c-2.5-.9-1.7.8-3 3.2s2.1 2.5 4.6 3.1s.9-.9 2.6-4.4c.7-1.4-1.7-1.1-4.2-1.9"
              />
            </svg>
            <p class="text-stone-700 text-sm md:text-base font-light max-w-md mx-auto leading-relaxed">
              В момента няма ястия в тази категория. Моля, проверете отново по-късно или попитайте
              за нашите предложения на място!
            </p>
          </div>
        )
      }
    </section>
  </main>
</Layout>

<style>
  .menu-item:hover {
    background-color: rgba(140, 14, 14, 0.04);
  }
</style>
