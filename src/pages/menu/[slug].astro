---
import { BASE_URL } from "../../constants.ts";
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const menuEntries = await getCollection("menu");
  return menuEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"menu">;
}

const { entry } = Astro.props;
const { categoryTitle, categoryDate, items } = entry.data;

// Formats a number as "5.90" style (always 2 decimals) regardless of how it's stored in the data file
const fmt = (n: number) => n.toFixed(2);
---

<Layout title={`${categoryTitle} - Ресторант Старата къща`}>
  <main class="max-w-4xl w-full mx-auto px-4 md:px-8 py-10 md:py-14 grow">
    <section
      class="bg-[#faf7f0] rounded-xl shadow-2xl p-6 md:p-12 border border-stone-200/50 mb-12 relative overflow-hidden"
    >
      <!-- Decorative top accent bar, matching the menu overview page -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-[#5c0606] via-[#8c0e0e] to-[#5c0606]"
      >
      </div>

      <!-- Back link -->
      <a
        href=`${BASE_URL}menu`
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase text-[#8c0e0e] hover:text-[#5c0606] transition-colors duration-200 mb-8"
      >
        <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
          <path
            d="M12.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L8.414 10l4.293 4.293a1 1 0 010 1.414z"
          ></path>
        </svg>
        Обратно към менюто
      </a>

      <header class="text-center mb-10 pb-8 border-b border-stone-200/70">
        <h1
          class="text-3xl md:text-5xl font-serif text-[#5c0606] font-bold tracking-wide uppercase"
        >
          {categoryTitle}
        </h1>
        {
          categoryDate && (
            <p class="text-xs md:text-sm text-stone-700 mt-3 tracking-wide">{categoryDate}</p>
          )
        }
      </header>

      <!-- Item list -->
      <ul class="divide-y divide-stone-200/70">
        {
          items.map((item) => (
            <>
              {item.subheading && (
                <li class="pt-16 pb-2 first:pt-0" aria-hidden="false">
                  <p class="text-xs text-center md:text-sm font-semibold tracking-[0.2em] uppercase text-[#8c0e0e]">
                    {item.subheading}
                  </p>
                </li>
              )}
              <li class="menu-item group flex items-start justify-between gap-4 py-4 md:py-5 px-2 md:px-3 rounded-md transition-colors duration-200">
                <div class="flex-1 min-w-0">
                  <p class="font-serif text-base md:text-lg text-stone-800 font-semibold leading-snug">
                    {item.name}
                    {item.note && (
                      <span class="ml-2 align-middle text-[10px] font-sans font-semibold uppercase tracking-wide text-[#8c0e0e] bg-[#8c0e0e]/10 rounded-full px-2 py-0.5">
                        {item.note}
                      </span>
                    )}
                  </p>
                  {item.weight && (
                    <p class="text-xs md:text-sm text-stone-500 mt-1">{item.weight}</p>
                  )}
                </div>

                <div class="text-right shrink-0 pt-0.5">
                  <p class="font-serif text-base md:text-lg font-bold text-[#8c0e0e] whitespace-nowrap">
                    {fmt(item.priceEur)}&nbsp;€
                  </p>
                  {item.priceBgn !== undefined && (
                    <p class="text-xs md:text-sm text-stone-700 whitespace-nowrap">
                      {fmt(item.priceBgn)}&nbsp;лв.
                    </p>
                  )}
                </div>
              </li>
            </>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>

<style>
  .menu-item:hover {
    background-color: rgba(140, 14, 14, 0.04);
  }
</style>
