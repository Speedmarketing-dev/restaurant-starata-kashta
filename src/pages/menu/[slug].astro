---
import { BASE_URL } from "../../utils/constants.ts";
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const menuEntries = await getCollection("menu");
  return menuEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"menu">;
}

const { entry } = Astro.props;
const { categoryTitle, categoryDate, items } = entry.data;

// Formats number to always show 2 decimals (e.g., 5.90)
const fmt = (n: number) => n.toFixed(2);

// --- Build schema.org Menu structured data ---
type MenuItemSchema = {
  "@type": "MenuItem";
  name: string;
  description?: string;
  offers?: {
    "@type": "Offer";
    price: string;
    priceCurrency: string;
  };
};

function toMenuItemSchema(item: (typeof items)[number]): MenuItemSchema | null {
  if (!item.name) return null;
  const schema: MenuItemSchema = {
    "@type": "MenuItem",
    name: item.name,
  };

  const descParts = [item.weight, item.note].filter(Boolean);
  if (descParts.length > 0) {
    schema.description = descParts.join(" — ");
  }

  if (item.priceEur !== undefined && item.priceEur !== null) {
    schema.offers = {
      "@type": "Offer",
      price: fmt(item.priceEur),
      priceCurrency: "EUR",
    };
  }
  return schema;
}

const looseItems: MenuItemSchema[] = [];
const sections: { "@type": "MenuSection"; name: string; hasMenuItem: MenuItemSchema[] }[] = [];

for (const item of items ?? []) {
  const schema = toMenuItemSchema(item);
  if (!schema) continue;

  if (item.subheading) {
    sections.push({ "@type": "MenuSection", name: item.subheading, hasMenuItem: [schema] });
  } else if (sections.length > 0) {
    sections[sections.length - 1].hasMenuItem.push(schema);
  } else {
    looseItems.push(schema);
  }
}

const hasStructuredMenu = looseItems.length > 0 || sections.length > 0;

const menuSchema = hasStructuredMenu
  ? {
      "@context": "https://schema.org",
      "@type": "Menu",
      name: categoryTitle,
      url: new URL(Astro.url.pathname, Astro.site || "https://staratakashta-bg.com").toString(),
      ...(looseItems.length > 0 && { hasMenuItem: looseItems }),
      ...(sections.length > 0 && { hasMenuSection: sections }),
    }
  : null;
---

<Layout title={`${categoryTitle} - Ресторант Старата къща`}>
  {menuSchema && <script type="application/ld+json" set:html={JSON.stringify(menuSchema)} />}
  <main class="max-w-4xl w-full mx-auto px-4 md:px-8 py-6 grow">
    <section
      class="bg-[#faf5eb] rounded-2xl shadow-2xl p-6 sm:p-8 md:p-12 border border-[#e2d4b7] mb-12 relative overflow-hidden"
    >
      <!-- Decorative top accent line -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-[#4a0808] via-[#8c0e0e] to-[#d97706]"
      >
      </div>

      <!-- Back to Menu Button -->
      <a
        href={`${BASE_URL}menu`}
        class="inline-flex items-center gap-2 text-xs font-bold tracking-widest uppercase text-[#8c0e0e] hover:text-[#4a0808] transition-colors duration-200 mb-8 group"
      >
        <svg
          class="h-4 w-4 fill-current transition-transform duration-200 group-hover:-translate-x-1"
          viewBox="0 0 20 20"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
            clip-rule="evenodd"></path>
        </svg>
        Обратно към менюто
      </a>

      <!-- Category Title Header -->
      <header class="text-center mb-8 pb-8 border-b border-[#e2d4b7]">
        <h1
          class="text-3xl sm:text-4xl md:text-5xl font-serif text-[#4a0808] font-bold tracking-wide uppercase"
        >
          {categoryTitle}
        </h1>
        {
          categoryDate && (
            <p class="text-xs md:text-sm font-mono text-stone-600 mt-2 tracking-wide bg-amber-500/10 border border-amber-500/20 px-3 py-1 rounded-full inline-block">
              Актуално към {categoryDate}
            </p>
          )
        }
      </header>

      <!-- Menu Items List -->
      {items && items.length > 0 ? (
          <ul>
            {items.map((item) => (
              <li class="py-3.5 first:pt-0 last:pb-0">
                {item.subheading && (
                  <div class="pt-6 pb-4 flex items-center gap-4">
                    <span class="h-px bg-[#e2d4b7] grow" />
                    <h2 class="text-xs text-center sm:text-sm font-bold tracking-[0.2em] uppercase text-[#8c0e0e] bg-[#8c0e0e]/10 px-4 py-1.5 rounded-full border border-[#8c0e0e]/20">
                      {item.subheading}
                    </h2>
                    <span class="h-px bg-[#e2d4b7] grow" />
                  </div>
                )}
                <div class="menu-item group flex items-baseline justify-between gap-4 px-3 py-2 rounded-xl transition-colors duration-200 hover:bg-[#8c0e0e]/5">
                  <div class="flex-1 min-w-0 pr-2">
                    <div class="flex items-baseline gap-2 flex-wrap">
                      <span class="font-serif text-base sm:text-lg text-stone-900 font-bold leading-snug">
                        {item.name}
                      </span>
                      {item.note && (
                        <span class="text-[12px] font-semibold uppercase tracking-wider text-[#8c0e0e] bg-[#8c0e0e]/10 border border-[#8c0e0e]/20 rounded-md px-4 py-1.5">
                          {item.note}
                        </span>
                      )}
                    </div>
                    {item.weight && (
                      <span class="text-xs text-stone-600 block mt-0.5">
                        {item.weight}
                      </span>
                    )}
                  </div>

                  <!-- Prices Column -->
                  <div class="text-right shrink-0">
                    {item.priceEur !== undefined && item.priceEur !== null && (
                      <span class="font-serif text-base sm:text-lg font-bold text-[#8c0e0e] whitespace-nowrap block">
                        {fmt(item.priceEur)}&nbsp;€
                      </span>
                    )}
                    {item.priceBgn !== undefined && item.priceBgn !== null && (
                      <span class="text-xs text-stone-600 whitespace-nowrap block">
                        {fmt(item.priceBgn)}&nbsp;лв.
                      </span>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        ) : (
          /* Empty State Fallback */
          <div class="flex flex-col items-center gap-4 py-16 px-4 text-center">
            <div class="w-16 h-16 rounded-full bg-amber-500/10 border border-amber-500/30 flex items-center justify-center text-amber-600 mb-2">
              <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24">
                <path d="M12 3a9 9 0 00-9 9v1h18v-1a9 9 0 00-9-9zm-7 12v2a2 2 0 002 2h10a2 2 0 002-2v-2H5z" />
              </svg>
            </div>
            <p class="font-serif font-bold text-lg text-[#4a0808]">
              В момента няма публикувани ястия в тази категория
            </p>
            <p class="text-stone-600 text-sm max-w-md font-light leading-relaxed">
              Моля, проверете отново по-късно или попитайте нашия екип за специалните предложения
              на място!
            </p>
            <a href={`${BASE_URL}menu`} class="mt-4 btn-primary">
              Разгледайте другите категории
            </a>
          </div>
        )
      }
    </section>
  </main>
</Layout>