---
import Layout from "../layouts/Layout.astro";
import Slideshow from "../components/Slideshow.astro";
import { BASE_URL, CONTACT_INFO } from "../utils/constants";

const { phoneNumbers } = CONTACT_INFO;
---

<Layout title="Ресторант Старата къща - Начало | София, кв. Редута">
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 mb-8 grow">
    <!-- Primary Hero Content Card -->
    <section
      class="bg-parchment rounded-2xl shadow-2xl p-12 border border-parchment-border mb-8 relative overflow-hidden"
      aria-labelledby="main-heading"
    >
      <!-- Top decorative crimson-to-gold accent line -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-burgundy-deep via-burgundy-brand to-gold-amber"
      >
      </div>

      <!-- Full-Width Header at the Top -->
      <header class="mb-8 border-b border-parchment-border pb-6">
        <div
          class="text-sm md:text-base font-semibold tracking-wider text-burgundy-brand mb-2 flex items-center gap-2"
        >
          Ресторант - градина Старата къща
        </div>
        <h1
          id="main-heading"
          class="text-3xl sm:text-4xl md:text-5xl font-serif text-burgundy-deep leading-tight tracking-tight uppercase font-bold text-center"
        >
          Ретро музика, уют и<br />
          <span class="text-burgundy-brand">българска кухня</span>
        </h1>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-stretch">
        <!-- Left Side: Warm Welcome Text -->
        <article class="lg:col-span-6 flex flex-col justify-center">
          <div class="mb-4 text-stone-700 text-sm md:text-base font-light">
            <p>
              Ресторант - градина <strong class="text-burgundy-brand">Старата къща</strong> се намира
              в София, квартал Редута. На пет минути от центъра на София и в същото време на тихо и спокойно
              място далеч от градския шум.
            </p>
            <p>
              Тук можете да опитате както традиционни български салати и ястия, така и нашите
              авторски специалитети, приготвени с майсторство и внимание.
            </p>
            <p>
              Всичко това сред естествената зеленина и дарът от природата – нашата 30-годишна лоза,
              под чиято сянка ще прекарате незабравими моменти.
            </p>
          </div>

          <div class="flex flex-col items-center">
            <!-- Retro Music Highlight Callout -->
            <div
              class="mt-2 p-4 rounded-xl bg-burgundy-brand/10 border-l-4 border-burgundy-brand flex items-start gap-2 max-w-100"
            >
              <svg
                class="w-5 h-5 text-burgundy-brand shrink-0 mt-0.5 fill-current"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V4a1 1 0 001-1z"
                ></path>
              </svg>
              <p class="font-medium text-burgundy-deep italic leading-snug text-pretty">
                Тук можете да чуете вечните евъргрийни - както български класики, така и световни
                рокендрол парчета.
              </p>
            </div>

            <!-- Hero Action CTAs -->
            <div class="mt-6 pt-2 flex justify-center flex-wrap gap-4">
              <a href={`${BASE_URL}menu`} class="btn-primary tracking-wider w-62.75">
                Разгледайте менюто
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                    clip-rule="evenodd"></path>
                </svg>
              </a>
              <a href={`${BASE_URL}contacts`} class="btn-gold tracking-wider w-62.75">
                Резервирайте маса
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="1em"
                  height="1em"
                  viewBox="0 0 20 20"
                >
                  <path d="M0 0h20v20H0z" fill="none"></path>
                  <path
                    fill="currentColor"
                    d="M17.256 12.253c-.096-.667-.611-1.187-1.274-1.342c-2.577-.604-3.223-2.088-3.332-3.734C12.193 7.092 11.38 7 10 7s-2.193.092-2.65.177c-.109 1.646-.755 3.13-3.332 3.734c-.663.156-1.178.675-1.274 1.342l-.497 3.442C2.072 16.907 2.962 18 4.2 18h11.6c1.237 0 2.128-1.093 1.953-2.305zM10 15.492c-1.395 0-2.526-1.12-2.526-2.5s1.131-2.5 2.526-2.5s2.526 1.12 2.526 2.5s-1.132 2.5-2.526 2.5M19.95 6c-.024-1.5-3.842-3.999-9.95-4C3.891 2.001.073 4.5.05 6s.021 3.452 2.535 3.127c2.941-.381 2.76-1.408 2.76-2.876C5.345 5.227 7.737 4.98 10 4.98s4.654.247 4.655 1.271c0 1.468-.181 2.495 2.76 2.876C19.928 9.452 19.973 7.5 19.95 6"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </article>

        <!-- Right Side: The Slideshow Panel -->
        <div class="lg:col-span-6 h-85 sm:h-100 lg:h-auto min-h-85">
          <Slideshow />
        </div>
      </div>
    </section>

    <!-- Lunch Menu Banner -->
    <section
      class="bg-linear-to-r from-tavern-card via-tavern-border to-tavern-card border border-amber-500/30 text-white rounded-2xl shadow-xl p-6 mb-8 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden"
      aria-label="Обедно меню"
    >
      <div class="flex items-center gap-4 sm:gap-6">
        <!-- Icon Badge -->
        <div
          class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-amber-500/20 border border-amber-500/40 flex items-center justify-center shrink-0 text-amber-400 shadow-inner"
        >
          <svg class="w-6 h-6 fill-current text-amber-400" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 3a9 9 0 00-9 9v1h18v-1a9 9 0 00-9-9zm-7 12v2a2 2 0 002 2h10a2 2 0 002-2v-2H5z"
            ></path>
          </svg>
        </div>
        <div>
          <span class="text-amber-400 block mb-2"> Всеки делничен ден </span>
          <h2
            class="text-xl sm:text-2xl font-serif font-bold text-white leading-tight tracking-[-0.015em]"
          >
            Разнообразно ежедневно обедно меню
          </h2>
          <p class="text-stone-300 mt-2 font-light max-w-xl">
            Прясно приготвени супи, традиционни български готвени ястия, скара и десерти.
          </p>
        </div>
      </div>

      <!-- Action Link -->
      <a
        href={`${BASE_URL}menu/obedno-menyu`}
        class="shrink-0 btn-gold w-full md:w-auto tracking-wider"
      >
        Вижте обедното меню &rarr;
      </a>
    </section>

    <!-- Lower Feature Cards Grid (Unified Architecture) -->
    <section
      class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mb-8"
      aria-label="Раздели и оферти"
    >
      <!-- Box 1: Festive Offers -->
      <article class="card-tavern-dark flex flex-col justify-between overflow-hidden">
        <div>
          <!-- Top image container -->
          <div class="w-full h-48 sm:h-52 overflow-hidden relative group">
            <img
              src={`${BASE_URL}images/gallery/IMG_6788.webp`}
              alt="Празнични оферти в градината на Старата Къща"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-tavern-card via-transparent to-transparent opacity-80"
            >
            </div>
          </div>
          <!-- Card Content -->
          <div class="p-6">
            <span class="text-amber-500 mb-2 flex items-center gap-2">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path
                  d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM14 11a1 1 0 011 1v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1h-1a1 1 0 110-2h1v-1a1 1 0 011-1z"
                ></path>
              </svg>
              Тържества & Събития
            </span>
            <h2 class="text-2xl font-serif text-white font-bold mb-3 tracking-[-0.015em]">
              Празнични оферти
            </h2>
            <p class="text-stone-300 font-light">
              Приемаме заявки за вашите рождени дни, кръщенета, семейни тържества, юбилеи и фирмени
              празници.
            </p>
          </div>
        </div>
        <div class="p-6 pt-0">
          <a href={`${BASE_URL}contacts`} class="w-full btn-outline-gold tracking-wider">
            Запитване за тържество
          </a>
        </div>
      </article>

      <!-- Box 2: About & Menu -->
      <article class="card-tavern-dark flex flex-col justify-between overflow-hidden">
        <div>
          <!-- Top image container -->
          <div class="w-full h-48 sm:h-52 overflow-hidden relative group">
            <img
              src={`${BASE_URL}images/gallery/IMG_6772.webp`}
              alt="Уютен интериор в ресторант Старата Къща"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-tavern-card via-transparent to-transparent opacity-80"
            >
            </div>
          </div>
          <!-- Card Content -->
          <div class="p-6">
            <span class="text-amber-500 mb-2 flex items-center gap-2">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
                  clip-rule="evenodd"></path>
              </svg>
              Традиция & Вкус
            </span>
            <h2 class="text-2xl font-serif text-white font-bold mb-3 tracking-[-0.015em]">
              За нас и менюто
            </h2>
            <p class="text-stone-300 font-light">
              Богато меню с класически български рецепти, автентичен майсторски грил, пресни салати
              и авторски ястия.
            </p>
          </div>
        </div>
        <div class="p-6 pt-0">
          <a href={`${BASE_URL}menu`} class="w-full btn-gold tracking-wider">
            Разгледайте менюто
          </a>
        </div>
      </article>

      <!-- Box 3: Reservation Panel -->
      <article class="card-tavern-dark flex flex-col justify-between overflow-hidden">
        <div>
          <!-- Top image container -->
          <div class="w-full h-48 sm:h-52 overflow-hidden relative group">
            <img
              src={`${BASE_URL}images/gallery/IMG_6790.webp`}
              alt="Вход към градината на Старата Къща"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-tavern-card via-transparent to-transparent opacity-80"
            >
            </div>
          </div>
          <!-- Card Content -->
          <div class="p-6">
            <span class="text-amber-500 mb-2 flex items-center gap-2">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path
                  d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                ></path>
              </svg>
              Бърза Резервация
            </span>
            <h2 class="text-2xl font-serif text-white font-bold mb-3 tracking-[-0.015em]">
              Направете резервация
            </h2>
            <p class="text-stone-300 font-light mb-4">
              Свържете се с нас за маса в градината или салона:
            </p>
            <!-- Direct Phone Links with SVG icons -->
            <ul class="space-y-2 mb-2">
              {
                phoneNumbers.map((phoneNumber) => (
                  <li>
                    <a
                      href={`tel:${phoneNumber.replace(/\s/g, "")}`}
                      class="text-amber-400 hover:text-white transition-colors font-mono text-xs sm:text-sm flex items-center gap-2"
                    >
                      {phoneNumber}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
        <div class="p-6 pt-0">
          <a href={`${BASE_URL}contacts`} class="w-full btn-outline-gold tracking-wider">
            Всички контакти
          </a>
        </div>
      </article>
    </section>
  </main>
</Layout>
