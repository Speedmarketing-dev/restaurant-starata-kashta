---
import Layout from "../layouts/Layout.astro";
import Slideshow from "../components/Slideshow.astro";
import { BASE_URL, CONTACT_INFO } from "../utils/constants";

const { phoneNumbers } = CONTACT_INFO;
---

<Layout title="Ресторант Старата къща - Начало">
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 py-4 grow">
    <!-- Primary Content Card -->
    <section
      class="bg-[#faf7f0] rounded-lg shadow-2xl p-6 md:p-10 border border-stone-200/50 mb-10"
      aria-labelledby="main-heading"
    >
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        <!-- Left Side: Warm Welcome Text -->
        <article class="lg:col-span-5 flex flex-col justify-center">
          <header class="mb-6">
            <h1
              id="main-heading"
              class="text-2xl md:text-3xl font-serif text-[#5c0606] leading-snug tracking-wide uppercase font-bold border-b border-stone-200 pb-4"
            >
              Ретро музика, уют и<br />
              <span class="text-[#8c0e0e]">българска кухня</span>
            </h1>
          </header>

          <div class="space-y-4 text-stone-700 text-sm md:text-base leading-relaxed font-light">
            <p>
              Ресторант - градина <strong>Старата къща</strong> се намира в София, квартал Редута. На
              пет минути от центъра на София и в същото време на тихо и спокойно място далеч от градския
              шум.
            </p>
            <p>
              Тук можете да опитате както традиционни салати и ястия, така и нашите авторски
              предложения.
            </p>
            <p>
              Всичко това сред естествената зеленина и дарът от природата, нашата лоза, под която да
              прекарате незабравими моменти.
            </p>
            <p class="font-medium text-[#5c0606] italic">
              Тук можете да чуете вечните евъргрийни както български, така и световни (рок енд рол).
            </p>
          </div>
        </article>

        <!-- Right Side: The Slideshow Panel -->
        <div class="lg:col-span-7 h-[350px] lg:h-auto">
          <Slideshow />
        </div>
      </div>
    </section>

    <!-- Lunch Menu Call to Action Banner -->
    <section
      class="bg-linear-to-r from-[#210909] via-[#380202] to-[#210909] border border-[#5c0606] text-white rounded-xl shadow-xl p-6 md:p-8 mb-10 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden"
      aria-label="Обедно меню"
    >
      <div class="flex items-center gap-4 md:gap-6">
        <!-- Icon Badge -->
        <div
          class="w-12 h-12 md:w-14 md:h-14 rounded-full bg-amber-500/15 border border-amber-500/30 flex items-center justify-center shrink-0 text-2xl text-amber-400"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 16 16">
            <path d="M0 0h16v16H0z" fill="none"></path>
            <path
              fill="#fff"
              d="M7.5 3c-.277 0-.5.223-.5.5V4H2.5a.499.499 0 1 0 0 1h11a.499.499 0 1 0 0-1H9v-.5c0-.277-.223-.5-.5-.5zM3 6v5.5c0 .831.669 1.5 1.5 1.5h7c.831 0 1.5-.669 1.5-1.5V6z"
            ></path>
          </svg>
        </div>
        <div>
          <span
            class="text-[10px] md:text-xs tracking-[0.25em] uppercase font-bold text-amber-400 block mb-1"
          >
            Всеки делничен ден
          </span>
          <h2 class="text-xl md:text-2xl font-serif font-bold text-white leading-tight">
            Разнообразно обедно меню
          </h2>
          <p class="text-stone-300 text-xs md:text-sm mt-1 font-light max-w-xl">
            Прясно приготвени супи, традиционни български готвени ястия, скара и десерти.
          </p>
        </div>
      </div>

      <!-- Action Link -->
      <a
        href={`${BASE_URL}menu/obedno-menyu`}
        class="shrink-0 bg-amber-500 hover:bg-amber-400 text-[#210909] font-bold text-xs md:text-sm tracking-wider uppercase px-6 py-3.5 rounded-full transition-all duration-200 shadow-lg text-center w-full md:w-auto"
      >
        Вижте обедното меню &rarr;
      </a>
    </section>

    <!-- Lower Content Cards (Rebuilt to Match Mockup) -->
    <section
      class="grid grid-cols-1 md:grid-cols-3 sm:grid-cols-2 gap-8 mb-12"
      aria-label="Раздели и оферти"
    >
      <!-- Box 1: Festive Offers -->
      <article
        class="bg-[#2a0101]/95 text-stone-100 rounded-xl overflow-hidden border border-[#3d1a1a] shadow-xl flex flex-col justify-between hover:border-amber-500/20 transition-all duration-300"
      >
        <div>
          <!-- Top edge-to-edge figure wrapper -->
          <div class="w-full h-48 overflow-hidden relative">
            <img
              src="https://staratakashta-bg.com/modules/mod_btslideshow/images/98/slideshow/starata-kashta-pic-2.jpg"
              alt="Празнични оферти в Старата Къща"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <!-- Left-aligned content layout -->
          <div class="p-6 grow">
            <span
              class="text-[10px] tracking-[0.25em] uppercase font-bold text-amber-500/80 mb-2 block"
              >Тържества</span
            >
            <h2 class="text-xl font-serif text-white font-semibold mb-3">Празнични оферти</h2>
            <p class="text-stone-300/80 text-sm leading-relaxed">
              Приемаме заявки за Вашите рождени дни, кръщенета, годишнини и други празници.
            </p>
          </div>
        </div>
      </article>

      <!-- Box 2: About Us -->
      <article
        class="bg-[#2a0101]/95 text-stone-100 rounded-xl overflow-hidden border border-[#3d1a1a] shadow-xl flex flex-col justify-between hover:border-amber-500/20 transition-all duration-300"
      >
        <div>
          <!-- Top edge-to-edge figure wrapper -->
          <div class="w-full h-48 overflow-hidden relative">
            <img
              src="https://staratakashta-bg.com/modules/mod_btslideshow/images/98/slideshow/starata-kashta-pic-2.jpg"
              alt="Снимка на интериора"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <!-- Left-aligned content layout -->
          <div class="p-6">
            <span
              class="text-[10px] tracking-[0.25em] uppercase font-bold text-amber-500/80 mb-2 block"
              >Кухня</span
            >
            <h2 class="text-xl font-serif text-white font-semibold mb-3">За нас</h2>
            <p class="text-stone-300/80 text-sm leading-relaxed mb-6">
              Разнообразно меню, включително и обедно, в което преобладава българската кухня.
            </p>
          </div>
        </div>
        <!-- Centered pill-shaped action button at bottom -->
        <div class="px-6 pb-6 mt-auto">
          <a
            href=`${BASE_URL}menu`
            class="w-full block text-center bg-[#8c0e0e] hover:bg-[#5c0606] text-white text-xs font-bold tracking-widest uppercase py-3.5 rounded-full transition-all duration-200"
          >
            Разгледайте менюто
          </a>
        </div>
      </article>

      <!-- Box 3: Reservation Panel -->
      <article
        class="bg-[#2a0101]/95 text-stone-100 rounded-xl overflow-hidden border border-[#3d1a1a] shadow-xl flex flex-col justify-between hover:border-amber-500/20 transition-all duration-300"
      >
        <div>
          <!-- Top edge-to-edge figure wrapper -->
          <div class="w-full h-48 overflow-hidden relative">
            <img
              src="https://staratakashta-bg.com/modules/mod_btslideshow/images/98/slideshow/starata-kashta-pic-2.jpg"
              alt="Градина на Старата Къща"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <!-- Left-aligned content layout -->
          <div class="p-6 grow">
            <span
              class="text-[10px] tracking-[0.25em] uppercase font-bold text-amber-500/80 mb-2 block"
              >Контакт</span
            >
            <h2 class="text-xl font-serif text-white font-semibold mb-3">Направете резервация</h2>
            <p class="text-stone-300/80 text-sm leading-relaxed mb-4">
              Свържете се с нас на телефони:
            </p>
            <!-- Direct Block Amber Links -->
            <ul class="space-y-2 mt-auto">
              {
                phoneNumbers.map((phoneNumber) => (
                  <li>
                    <a
                      href={`tel:${phoneNumber.replace(/\s/g, "")}`}
                      class="text-amber-500 hover:text-white transition-colors font-mono font-medium text-sm md:text-base block"
                    >
                      {phoneNumber}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </article>
    </section>
  </main>
</Layout>
