---
import Layout from "../layouts/Layout.astro";
import { BASE_URL } from "../utils/constants";
---

<Layout title="404 - Страницата не е намерена - Ресторант Старата къща">
  <main
    class="max-w-4xl w-full mx-auto px-4 md:px-8 py-16 md:py-24 grow flex items-center justify-center"
  >
    <section
      class="bg-[#faf7f0] rounded-md shadow-2xl p-8 md:p-16 border border-stone-200/50 text-center relative overflow-hidden max-w-lg w-full"
    >
      <!-- Decorative top accent bar -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-[#5c0606] via-[#8c0e0e] to-[#5c0606]"
      >
      </div>

      <!-- Large Elegant Error Code -->
      <div class="mb-6 text-7xl md:text-8xl font-serif font-bold text-[#8c0e0e] tracking-tight">
        404
      </div>

      <h1
        class="text-2xl md:text-3xl font-serif text-[#5c0606] font-bold tracking-wide uppercase mb-4"
      >
        Страницата не е намерена
      </h1>

      <p class="text-stone-700 text-sm md:text-base leading-relaxed font-light mb-6">
        Тази страница не съществува. Върнете се в началната страница или вижте нашите предложения в
        менюто.
      </p>

      <!-- Action Navigation Links (Dynamic base paths) -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={BASE_URL}
          class="bg-[#8c0e0e] hover:bg-[#5c0606] text-white text-xs font-bold tracking-widest uppercase px-8 py-4 rounded-lg transition-all duration-200 shadow-md text-center"
        >
          Начало
        </a>
        <a
          href={`${BASE_URL}menu`}
          class="border-2 border-stone-300 hover:border-[#8c0e0e] text-stone-700 hover:text-[#8c0e0e] text-xs font-bold tracking-widest uppercase px-8 py-4 rounded-lg transition-all duration-200 text-center"
        >
          Вижте Менюто
        </a>
      </div>
    </section>
  </main>
</Layout>
