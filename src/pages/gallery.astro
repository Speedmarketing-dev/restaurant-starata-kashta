---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { BASE_URL } from "../utils/constants";
import Image from "astro/components/Image.astro";
import { buildGalleryPhotos } from "../utils/gallery";

// 1. Fetch raw gallery collection entries from YAML files
const entriesRaw = await getCollection("gallery");

// 2. Build full photo list using utility function
const photos = buildGalleryPhotos(entriesRaw);

// 3. Dynamically map unique categories from YAML entries sorted by 'order'
const categoryMap = new Map<string, string>(); // category ID/slug -> Category Label
const categoryOrder = new Map<string, number>();

entriesRaw.forEach((entry) => {
  const catName = entry.data.category || entry.id;
  categoryMap.set(entry.id, catName);
  categoryOrder.set(entry.id, entry.data.order ?? 99);
});

// Convert map to sorted filter tabs array
const dynamicCategories = Array.from(categoryMap.entries())
  .sort((a, b) => (categoryOrder.get(a[0]) ?? 99) - (categoryOrder.get(b[0]) ?? 99))
  .map(([id, label]) => ({ key: id, label }));

// Always include "Всички" (All) as the first filter tab
const filterTabs = [{ key: "all", label: "Всички снимки" }, ...dynamicCategories];

// Items per page in grid view
const PAGE_SIZE = 12;
---

<Layout
  title="Галерия - Ресторант Старата къща | София, кв. Редута"
  description="Разгледайте снимки от прохладната ни лятна градина под лозата и автентичния интериор на ресторант Старата къща в София."
>
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 py-6 grow">
    <section
      id="gallery-section"
      class="bg-parchment rounded-2xl shadow-2xl p-6 sm:p-8 md:p-12 border border-parchment-border mb-12 relative overflow-hidden"
    >
      <!-- Decorative top crimson-to-gold accent line -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-burgundy-deep via-burgundy-brand to-gold-amber"
      >
      </div>

      <!-- Section Header -->
      <header class="text-center max-w-2xl mx-auto mb-6 pb-6 border-b border-parchment-border">
        <span
          class="text-xs md:text-sm font-semibold tracking-[0.25em] uppercase text-burgundy-brand mb-2 block"
        >
          Уютна Атмосфера & Градина
        </span>
        <h1
          class="text-3xl sm:text-4xl md:text-5xl font-serif text-burgundy-deep font-bold tracking-tight uppercase mb-4"
        >
          Галерия
        </h1>
        <p class="text-stone-600 text-sm md:text-base leading-relaxed font-light">
          Потопете се в духа на Старата къща — от сенчестата лятна градина под асмата до битовия салон.
        </p>

        <!-- Dynamically Generated Category Filter Tabs -->
        {
          filterTabs.length > 1 && (
            <div class="flex flex-wrap justify-center gap-2 mt-6" id="gallery-filters">
              {filterTabs.map((cat, idx) => (
                <button
                  type="button"
                  data-filter={cat.key}
                  class={`gallery-filter-btn text-xs font-semibold tracking-wider uppercase px-4 py-2 rounded-full border transition-all shadow-xs cursor-pointer ${
                    idx === 0
                      ? "active border-burgundy-brand bg-burgundy-brand text-white"
                      : "border-parchment-border bg-white text-stone-700 hover:border-burgundy-brand hover:text-burgundy-brand"
                  }`}
                >
                  {cat.label}
                </button>
              ))}
            </div>
          )
        }
      </header>

      <!-- Photo Grid -->
      <div
        id="gallery-grid"
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
      >
        {
          photos.map((photo, index) => {
            const page = Math.floor(index / PAGE_SIZE) + 1;
            return (
              <button
                type="button"
                class="gallery-thumb group relative aspect-square w-full overflow-hidden rounded-xl border border-parchment-border bg-stone-100 shadow-sm hover:shadow-xl hover:border-amber-500/50 transition-all duration-300 cursor-pointer"
                data-index={index}
                data-page={page}
                data-group={photo.groupKey}
                style={page === 1 ? undefined : "display:none"}
                aria-label={`Отвори снимка: ${photo.alt}`}
              >
                <Image
                  src={`${BASE_URL}${photo.src}`}
                  alt={photo.alt}
                  width={300}
                  height={300}
                  loading="lazy"
                  class="gallery-thumb-img absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-108"
                />
                <!-- Gradient Vignette Overlay -->
                <div class="absolute inset-0 bg-linear-to-t from-tavern-card/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />

                <!-- Zoom Icon Affordance -->
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 transform scale-90 group-hover:scale-100">
                  <div class="w-10 h-10 rounded-full bg-amber-500/90 text-stone-950 flex items-center justify-center shadow-lg backdrop-blur-xs">
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"></path>
                    </svg>
                  </div>
                </div>
              </button>
            );
          })
        }
      </div>

      <!-- Empty State Fallback -->
      {
        photos.length === 0 && (
          <div class="flex flex-col items-center justify-center py-16 text-center text-stone-700">
            <div class="w-16 h-16 rounded-full bg-burgundy-brand/10 border border-burgundy-brand/20 flex items-center justify-center text-burgundy-brand mb-4">
              <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24">
                <path d="M4 4h3l2-2h6l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2zm8 3a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z" />
              </svg>
            </div>
            <p class="font-serif font-bold text-lg text-burgundy-deep">Няма намерени снимки</p>
            <p class="text-sm text-stone-500 mt-1 max-w-sm">
              В момента албумът се обновява. Моля, проверете отново по-късно!
            </p>
          </div>
        )
      }

      <!-- Pagination Container -->
      {
        photos.length > PAGE_SIZE && (
          <nav
            id="gallery-pagination"
            class="flex flex-wrap items-center justify-center gap-2 mt-6 pt-6 border-t border-parchment-border"
            aria-label="Странициране на галерията"
          />
        )
      }
      <p id="gallery-page-status" class="sr-only" aria-live="polite"></p>
    </section>
  </main>

  <!-- Lightbox Modal Container -->
  <div
    id="lightbox"
    class="lightbox fixed inset-0 z-50 flex items-center justify-center p-4 md:p-8 opacity-0 pointer-events-none transition-opacity duration-300"
    role="dialog"
    aria-modal="true"
    aria-label="Преглед на снимка"
  >
    <div id="lightbox-backdrop" class="absolute inset-0 bg-black/85 backdrop-blur-md"></div>

    <!-- Close Button -->
    <button
      id="lightbox-close"
      type="button"
      class="absolute top-4 right-4 md:top-6 md:right-6 z-20 text-stone-200 hover:text-amber-400 p-3 rounded-full bg-black/50 hover:bg-black/80 border border-white/20 transition-all cursor-pointer"
      aria-label="Затвори"
    >
      <svg class="h-6 w-6 fill-current" viewBox="0 0 20 20" aria-hidden="true">
        <path
          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
        ></path>
      </svg>
    </button>

    <!-- Navigation Arrows -->
    <button
      id="lightbox-prev"
      type="button"
      class="absolute left-3 md:left-8 top-1/2 -translate-y-1/2 z-20 text-stone-200 hover:text-amber-400 p-3 bg-black/50 hover:bg-black/80 border border-white/20 rounded-full transition-all cursor-pointer"
      aria-label="Предишна снимка"
    >
      <svg class="h-6 w-6 fill-current" viewBox="0 0 20 20" aria-hidden="true">
        <path
          fill-rule="evenodd"
          d="M12.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L8.414 10l4.293 4.293a1 1 0 010 1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>

    <button
      id="lightbox-next"
      type="button"
      class="absolute right-3 md:right-8 top-1/2 -translate-y-1/2 z-20 text-stone-200 hover:text-amber-400 p-3 bg-black/50 hover:bg-black/80 border border-white/20 rounded-full transition-all cursor-pointer"
      aria-label="Следваща снимка"
    >
      <svg class="h-6 w-6 fill-current" viewBox="0 0 20 20" aria-hidden="true">
        <path
          fill-rule="evenodd"
          d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>

    <!-- Image Display -->
    <figure class="relative z-10 max-w-full max-h-full flex flex-col items-center">
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="lightbox-img max-w-[90vw] max-h-[78vh] object-contain rounded-xl border border-white/10 shadow-2xl"
      />
      <div class="mt-3 flex items-center gap-3">
        <span
          id="lightbox-counter"
          class="bg-amber-500/20 border border-amber-500/30 text-amber-400 text-xs px-3 py-0.5 rounded-full"
        ></span>
      </div>
    </figure>
  </div>
</Layout>

<style>
  .gallery-filter-btn.active {
    background-color: #8c0e0e;
    color: #ffffff;
    border-color: #8c0e0e;
    box-shadow: 0 2px 8px rgba(140, 14, 14, 0.3);
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script is:inline define:vars={{ lightboxPhotos: photos.map((p) => ({ src: `${BASE_URL}${p.src}`, alt: p.alt, group: p.groupKey })), pageSize: PAGE_SIZE }}>
  const grid = document.getElementById("gallery-grid");
  const gallerySection = document.getElementById("gallery-section");
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img");
  const lightboxCaption = document.getElementById("lightbox-caption");
  const lightboxCounter = document.getElementById("lightbox-counter");
  const closeBtn = document.getElementById("lightbox-close");
  const backdrop = document.getElementById("lightbox-backdrop");
  const prevBtn = document.getElementById("lightbox-prev");
  const nextBtn = document.getElementById("lightbox-next");
  const paginationNav = document.getElementById("gallery-pagination");
  const filterBtns = document.querySelectorAll(".gallery-filter-btn");

  let currentIndex = 0;
  let activeFilter = "all";

  // Returns photos active under the selected filter category
  function getFilteredPhotos() {
    if (activeFilter === "all") return lightboxPhotos;
    return lightboxPhotos.filter((p) => p.group === activeFilter);
  }

  function showPhoto(index) {
    const list = getFilteredPhotos();
    if (list.length === 0) return;

    currentIndex = (index + list.length) % list.length;
    const photo = list[currentIndex];
    if (lightboxImg) {
      lightboxImg.src = photo.src;
      lightboxImg.alt = photo.alt;
    }
    if (lightboxCounter) lightboxCounter.textContent = `${currentIndex + 1} / ${list.length}`;
  }

  function openLightbox(index) {
    showPhoto(index);
    lightbox?.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox?.classList.remove("is-open");
    document.body.style.overflow = "";
  }

  function bindThumbEvents() {
    const thumbs = grid ? Array.from(grid.querySelectorAll(".gallery-thumb")) : [];
    thumbs.forEach((thumb) => {
      thumb.onclick = () => {
        const index = parseInt(thumb.getAttribute("data-index") || "0", 10);
        const activeList = getFilteredPhotos();
        const targetPhoto = lightboxPhotos[index];
        const activeIndex = activeList.findIndex((p) => p.src === targetPhoto.src);
        openLightbox(activeIndex >= 0 ? activeIndex : 0);
      };
    });
  }

  closeBtn?.addEventListener("click", closeLightbox);
  backdrop?.addEventListener("click", closeLightbox);
  prevBtn?.addEventListener("click", () => showPhoto(currentIndex - 1));
  nextBtn?.addEventListener("click", () => showPhoto(currentIndex + 1));

  document.addEventListener("keydown", (e) => {
    if (!lightbox?.classList.contains("is-open")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") showPhoto(currentIndex - 1);
    if (e.key === "ArrowRight") showPhoto(currentIndex + 1);
  });

  // --- Filter and Pagination Logic ---
  let currentPage = 1;

  function updateDisplay() {
    const allThumbs = grid ? Array.from(grid.querySelectorAll(".gallery-thumb")) : [];
    const filteredThumbs = allThumbs.filter((thumb) => {
      const group = thumb.getAttribute("data-group");
      return activeFilter === "all" || group === activeFilter;
    });

    const totalPages = Math.max(1, Math.ceil(filteredThumbs.length / pageSize));
    currentPage = Math.min(currentPage, totalPages);

    // Hide all thumbs first
    allThumbs.forEach((thumb) => (thumb.style.display = "none"));

    // Show thumbs for current page in active group
    const startIdx = (currentPage - 1) * pageSize;
    const endIdx = startIdx + pageSize;
    filteredThumbs.slice(startIdx, endIdx).forEach((thumb) => {
      thumb.style.display = "";
    });

    renderPagination(totalPages);
  }

  function renderPagination(totalPages) {
    if (!paginationNav) return;
    if (totalPages <= 1) {
      paginationNav.style.display = "none";
      return;
    }
    paginationNav.style.display = "flex";

    let html = "";
    // Previous Page Button
    html += `<button type="button" data-page="${currentPage - 1}" ${currentPage === 1 ? "disabled" : ""} class="px-3 py-1.5 rounded-full text-xs font-semibold border border-parchment-border text-stone-700 hover:bg-burgundy-brand hover:text-white hover:border-burgundy-brand transition-colors disabled:opacity-30 disabled:pointer-events-none cursor-pointer">←</button>`;

    for (let p = 1; p <= totalPages; p++) {
      const isCurrent = p === currentPage;
      html += `<button type="button" data-page="${p}" class="w-8 h-8 rounded-full text-xs font-bold border transition-all cursor-pointer ${isCurrent ? "bg-burgundy-brand text-white border-burgundy-brand shadow-xs" : "border-parchment-border bg-white text-stone-700 hover:border-burgundy-brand"}">${p}</button>`;
    }

    // Next Page Button
    html += `<button type="button" data-page="${currentPage + 1}" ${currentPage === totalPages ? "disabled" : ""} class="px-3 py-1.5 rounded-full text-xs font-semibold border border-parchment-border text-stone-700 hover:bg-burgundy-brand hover:text-white hover:border-burgundy-brand transition-colors disabled:opacity-30 disabled:pointer-events-none cursor-pointer">→</button>`;

    paginationNav.innerHTML = html;

    paginationNav.querySelectorAll("button[data-page]").forEach((btn) => {
      btn.addEventListener("click", () => {
        currentPage = parseInt(btn.getAttribute("data-page") || "1", 10);
        updateDisplay();
        gallerySection?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  }

  // Filter Buttons Click Listeners
  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeFilter = btn.getAttribute("data-filter") || "all";
      currentPage = 1;
      updateDisplay();
    });
  });

  bindThumbEvents();
  updateDisplay();
</script>