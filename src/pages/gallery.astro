---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { BASE_URL } from "../utils/constants";
import Image from "astro/components/Image.astro";
import { buildGalleryPhotos } from "../utils/gallery";

const entriesRaw = await getCollection("gallery");
const photos = buildGalleryPhotos(entriesRaw);

// Pagination: how many photos show per page of the grid. The lightbox still
// lets visitors arrow through every photo regardless of page.
const PAGE_SIZE = 12;
---

<Layout title="Галерия - Ресторант Старата къща" description="Разгледайте снимки от прохладната ни лятна градина под лозата и автентичния интериор на ресторант Старата къща в София.">
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 py-10 md:py-14 grow">

    <section id="gallery-section" class="bg-[#faf7f0] rounded-xl shadow-2xl p-6 md:p-12 border border-stone-200/50 mb-12 relative overflow-hidden">

      <!-- Decorative top accent bar, matching the rest of the site -->
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-[#5c0606] via-[#8c0e0e] to-[#5c0606]"></div>

      <header class="text-center max-w-2xl mx-auto mb-12 pb-8 border-b border-stone-200/70">
        <h1 class="text-3xl md:text-5xl font-serif text-[#5c0606] font-bold tracking-wide uppercase mb-4">
          Галерия
        </h1>
        <p class="text-stone-600 text-sm md:text-base leading-relaxed font-light">
          Разгледайте атмосферата на Старата къща — от уютния интериор до сенчестата градина.
        </p>
      </header>

      <!-- Photo grid -->
      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-4">
        {photos.map((photo, index) => {
          const page = Math.floor(index / PAGE_SIZE) + 1;
          return (
            <button
              type="button"
              class="gallery-thumb group relative aspect-square w-full overflow-hidden rounded-lg border border-stone-200/70 bg-stone-100 shadow-sm"
              data-index={index}
              data-page={page}
              style={page === 1 ? undefined : "display:none"}
              aria-label={`Отвори снимка: ${photo.alt}`}
            >
              <Image
                src=`${BASE_URL}${photo.src}`
                alt={photo.alt}
                width={230}
                height={230}
                loading="lazy"
                class="gallery-thumb-img absolute inset-0 w-full h-full object-cover transition-transform duration-500"
              />
              <div class="absolute inset-0 bg-[#2a0303]/0 group-hover:bg-[#2a0303]/20 transition-colors duration-300"></div>
              <!-- Zoom affordance icon on hover -->
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <svg class="h-8 w-8 text-white drop-shadow-md" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="11" cy="11" r="7"></circle>
                  <line x1="11" y1="8" x2="11" y2="14"></line>
                  <line x1="8" y1="11" x2="14" y2="11"></line>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              </div>
            </button>
          );
        })}
      </div>

      {photos.length === 0 && (
        <p class="text-center text-stone-500 py-16">Няма добавени снимки все още.</p>
      )}

      {photos.length > PAGE_SIZE && (
        <nav
          id="gallery-pagination"
          class="flex-wrap items-center justify-center gap-1.5 md:gap-2 mt-10 pt-8 border-t border-stone-200/70"
          style="display:none;"
          aria-label="Странициране на галерията"
        ></nav>
      )}
      <p id="gallery-page-status" class="sr-only" aria-live="polite"></p>

    </section>
  </main>

  <!-- Lightbox overlay -->
  <div
    id="lightbox"
    class="lightbox fixed inset-0 z-50 flex items-center justify-center p-4 md:p-10 opacity-0 pointer-events-none"
    role="dialog"
    aria-modal="true"
    aria-label="Преглед на снимка"
  >
    <div id="lightbox-backdrop" class="absolute inset-0 bg-black/85"></div>

    <button
      id="lightbox-close"
      type="button"
      class="absolute top-4 right-4 md:top-6 md:right-6 z-10 text-white/80 hover:text-white p-2"
      aria-label="Затвори"
    >
      <svg class="h-7 w-7" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"></path>
      </svg>
    </button>

    <button
      id="lightbox-prev"
      type="button"
      class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 md:p-3 bg-black/30 hover:bg-black/50 rounded-full transition-colors"
      aria-label="Предишна снимка"
    >
      <svg class="h-6 w-6 md:h-7 md:w-7" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M12.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L8.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"></path>
      </svg>
    </button>

    <button
      id="lightbox-next"
      type="button"
      class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 md:p-3 bg-black/30 hover:bg-black/50 rounded-full transition-colors"
      aria-label="Следваща снимка"
    >
      <svg class="h-6 w-6 md:h-7 md:w-7" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M7.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L11.586 10 7.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
      </svg>
    </button>

    <figure class="relative z-0 max-w-full max-h-full flex flex-col items-center">
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="lightbox-img max-w-[90vw] max-h-[80vh] object-contain rounded-md shadow-2xl"
      />
      <p id="lightbox-counter" class="text-white/50 text-xs mt-2 tracking-wide"></p>
    </figure>
  </div>
</Layout>

<style>
  .gallery-thumb:hover .gallery-thumb-img {
    transform: scale(1.08);
  }

  .lightbox {
    transition: opacity 0.25s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .gallery-page-btn[aria-current="page"] {
    cursor: default;
  }
</style>

<script is:inline define:vars={{ lightboxPhotos: photos.map((p) => ({ src: `${BASE_URL}${p.src}`, alt: p.alt })), pageSize: PAGE_SIZE }}>
  const grid = document.getElementById("gallery-grid");
  const gallerySection = document.getElementById("gallery-section");
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img");
  const lightboxCounter = document.getElementById("lightbox-counter");
  const closeBtn = document.getElementById("lightbox-close");
  const backdrop = document.getElementById("lightbox-backdrop");
  const prevBtn = document.getElementById("lightbox-prev");
  const nextBtn = document.getElementById("lightbox-next");
  const paginationNav = document.getElementById("gallery-pagination");
  const pageStatus = document.getElementById("gallery-page-status");

  let currentIndex = 0;

  function showPhoto(index) {
    if (lightboxPhotos.length === 0) return;
    currentIndex = (index + lightboxPhotos.length) % lightboxPhotos.length;
    const photo = lightboxPhotos[currentIndex];
    lightboxImg.src = photo.src;
    lightboxImg.alt = photo.alt;
    lightboxCounter.textContent = `${currentIndex + 1} / ${lightboxPhotos.length}`;
  }

  function openLightbox(index) {
    showPhoto(index);
    lightbox?.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox?.classList.remove("is-open");
    document.body.style.overflow = "";
  }

  grid?.querySelectorAll(".gallery-thumb").forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const index = parseInt(thumb.getAttribute("data-index") || "0", 10);
      openLightbox(index);
    });
  });

  closeBtn?.addEventListener("click", closeLightbox);
  backdrop?.addEventListener("click", closeLightbox);
  prevBtn?.addEventListener("click", () => showPhoto(currentIndex - 1));
  nextBtn?.addEventListener("click", () => showPhoto(currentIndex + 1));

  document.addEventListener("keydown", (e) => {
    if (!lightbox?.classList.contains("is-open")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") showPhoto(currentIndex - 1);
    if (e.key === "ArrowRight") showPhoto(currentIndex + 1);
  });

  // --- Grid pagination ---------------------------------------------------
  const thumbs = grid ? Array.from(grid.querySelectorAll(".gallery-thumb")) : [];
  const totalPages = Math.max(1, Math.ceil(thumbs.length / pageSize));
  let currentPage = 1;

  function showThumbsForPage(page) {
    thumbs.forEach((thumb) => {
      const thumbPage = parseInt(thumb.getAttribute("data-page") || "1", 10);
      thumb.style.display = thumbPage === page ? "" : "none";
    });
  }

  function navButtonHTML(label, targetPage, disabled, ariaLabel) {
    return `
      <button
        type="button"
        data-page="${targetPage}"
        ${disabled ? "disabled" : ""}
        aria-label="${ariaLabel}"
        class="px-3 py-2 rounded-full text-sm border border-stone-300 text-stone-600 hover:bg-[#5c0606] hover:text-white hover:border-[#5c0606] transition-colors disabled:opacity-40 disabled:pointer-events-none disabled:hover:bg-transparent disabled:hover:text-stone-600"
      >${label}</button>
    `;
  }

  function pageButtonHTML(page) {
    const isCurrent = page === currentPage;
    return `
      <button
        type="button"
        data-page="${page}"
        aria-label="Страница ${page}"
        aria-current="${isCurrent ? "page" : "false"}"
        class="gallery-page-btn w-9 h-9 rounded-full text-sm font-medium border transition-colors ${
          isCurrent
            ? "bg-[#5c0606] text-white border-[#5c0606]"
            : "border-stone-300 text-stone-600 hover:bg-stone-100"
        }"
      >${page}</button>
    `;
  }

  function renderPaginationControls() {
    if (!paginationNav) return;

    if (totalPages <= 1) {
      paginationNav.style.display = "none";
      return;
    }
    paginationNav.style.display = "flex";

    const parts = [];
    parts.push(navButtonHTML("←", currentPage - 1, currentPage === 1, "Предишна страница"));

    const pagesToShow = new Set([1, totalPages, currentPage - 1, currentPage, currentPage + 1]);
    let prevShown = null;
    for (let p = 1; p <= totalPages; p++) {
      if (!pagesToShow.has(p)) continue;
      if (prevShown !== null && p - prevShown > 1) {
        parts.push(`<span class="px-1 text-stone-400 select-none">…</span>`);
      }
      parts.push(pageButtonHTML(p));
      prevShown = p;
    }

    parts.push(navButtonHTML("→", currentPage + 1, currentPage === totalPages, "Следваща страница"));

    paginationNav.innerHTML = parts.join("");

    paginationNav.querySelectorAll("button[data-page]").forEach((btn) => {
      btn.addEventListener("click", () => goToPage(parseInt(btn.getAttribute("data-page"), 10)));
    });
  }

  function goToPage(page) {
    currentPage = Math.min(Math.max(1, page), totalPages);
    showThumbsForPage(currentPage);
    renderPaginationControls();
    if (pageStatus) {
      pageStatus.textContent = `Страница ${currentPage} от ${totalPages}`;
    }
    gallerySection?.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  renderPaginationControls();
  if (pageStatus && totalPages > 1) {
    pageStatus.textContent = `Страница ${currentPage} от ${totalPages}`;
  }
</script>