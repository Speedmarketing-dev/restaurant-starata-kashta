---

<Layout
  title="Меню - Ресторант Старата къща | София, кв. Редута"
  description="Разгледайте пълното ни меню: традиционни български салати, скара, специалитети, алкохол и богато обедно меню в Редута."
>
  <main class="max-w-6xl w-full mx-auto px-4 md:px-8 mb-8 grow">
    <!-- Main Content Container -->
    <section
      class="bg-parchment rounded-2xl shadow-2xl p-6 md:p-12 border border-parchment-border mb-12 relative overflow-hidden"
    >
      <!-- Decorative top crimson accent bar -->
      <div
        class="absolute top-0 left-0 right-0 h-1.5 bg-linear-to-r from-burgundy-deep via-burgundy-brand to-gold-amber"
      >
      </div>

      <!-- Section Header -->
      <header class="text-center max-w-2xl mx-auto mb-8 pb-6 border-b border-parchment-border">
        <span
          class="text-sm md:text-base font-semibold tracking-wider text-burgundy-brand mb-2 block"
        >
          Традиционна Българска Кухня
        </span>
        <h1
          class="text-3xl sm:text-4xl md:text-5xl font-serif text-burgundy-deep font-bold tracking-tight uppercase mb-4"
        >
          Нашето Меню
        </h1>
        <p class="text-stone-600 text-sm md:text-base leading-relaxed font-light">
          Подбрани традиционни рецепти, майсторска скара и специални предложения.
        </p>

        <!-- Interactive Search Bar -->
        <div class="mt-4 max-w-lg mx-auto relative">
          <input
            type="search"
            id="category-search"
            placeholder="Търсене на категория (напр. Скара, Салати, Вина...)"
            class="w-full bg-white border border-parchment-border rounded-full py-3.5 pl-6 pr-12 text-sm text-stone-800 placeholder-stone-400 outline-none focus:border-burgundy-brand focus:ring-2 focus:ring-burgundy-brand/20 transition-all duration-200 shadow-sm"
            aria-label="Търсене на категория"
          />
          <span
            class="absolute right-4 top-1/2 -translate-y-1/2 text-burgundy-brand pointer-events-none"
            aria-hidden="true"
          >
            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z"
                clip-rule="evenodd"></path>
            </svg>
          </span>
        </div>

        <!-- Quick Group Filter Pills -->
        <div class="flex flex-wrap justify-center gap-2 mt-2">
          <button
            data-filter="all"
            class="filter-btn active text-xs font-semibold tracking-wider uppercase px-4 py-2 rounded-full border border-burgundy-brand bg-burgundy-brand text-white transition-all shadow-xs"
          >
            Всички
          </button>
          <button
            data-filter="dishes"
            class="filter-btn text-xs font-semibold tracking-wider uppercase px-4 py-2 rounded-full border border-parchment-border bg-white text-stone-700 hover:border-burgundy-brand hover:text-burgundy-brand transition-all"
          >
            Ястия & Скара
          </button>
          <button
            data-filter="drinks"
            class="filter-btn text-xs font-semibold tracking-wider uppercase px-4 py-2 rounded-full border border-parchment-border bg-white text-stone-700 hover:border-burgundy-brand hover:text-burgundy-brand transition-all"
          >
            Напитки & Вина
          </button>
          <button
            data-filter="lunch"
            class="filter-btn text-xs font-semibold tracking-wider uppercase px-4 py-2 rounded-full border border-amber-500/40 bg-amber-500/10 text-amber-900 hover:bg-amber-500 hover:text-stone-950 transition-all"
          >
            Обедно меню
          </button>
        </div>
      </header>

      <!-- Responsive Menu Categories Grid -->
      <div
        id="categories-grid"
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
      >
        {
          menuCategories.map((category) => {
            return (
              <a
                href={`${BASE_URL}menu/${category.slug}`}
                class="menu-card group relative bg-white rounded-xl border border-parchment-border overflow-hidden shadow-sm hover:shadow-xl hover:border-amber-500/50 transition-all duration-300 block w-full"
                data-title={category.title.toLowerCase()}
                data-subtitle={category.subtitle.toLowerCase()}
                data-group={category.group}
              >
                <!-- Image Container -->
                <div class="relative w-full aspect-16/10 overflow-hidden bg-stone-100">
                  <Image
                    src={category.img}
                    alt={`${category.title} - Ресторант Старата къща`}
                    class="menu-card-img absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-108"
                    loading="lazy"
                    width="400"
                    height="250"
                  />
                  <!-- Dark gradient overlay for typography readability -->
                  <div class="absolute inset-0 bg-linear-to-t from-tavern-card/95 via-tavern-card/40 to-transparent" />

                  <!-- Special Badge if lunch -->
                  {category.isSpecial && (
                    <span class="absolute top-3 left-3 bg-amber-500 text-stone-950 font-bold text-[10px] uppercase tracking-wider px-2.5 py-1 rounded-full shadow-md">
                      Специално за деня
                    </span>
                  )}

                  <!-- Bottom Title & Subtitle Container -->
                  <div class="absolute inset-x-0 bottom-0 p-4">
                    <h2 class="text-white font-serif font-bold text-lg md:text-2xl drop-shadow-md group-hover:text-amber-400 transition-colors">
                      {category.title}
                    </h2>
                    <p class="text-stone-300 text-xs font-light line-clamp-1 mt-2 opacity-90">
                      {category.subtitle}
                    </p>
                  </div>

                  <!-- Animated crimson accent bar on bottom border -->
                  <div class="absolute bottom-0 left-0 h-1 w-full bg-burgundy-brand origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300" />
                </div>
              </a>
            );
          })
        }
      </div>

      <!-- Search No Results State -->
      <div
        id="no-results"
        class="hidden flex-col items-center justify-center py-6 text-center text-stone-700"
      >
        <div
          class="w-16 h-16 rounded-full bg-burgundy-brand/10 border border-burgundy-brand/20 flex items-center justify-center text-burgundy-brand mb-4"
        >
          <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24">
            <path
              d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
            ></path>
          </svg>
        </div>
        <p class="font-serif font-bold text-lg text-burgundy-deep">
          Няма открити категории по този критерий
        </p>
        <p class="text-sm text-stone-600 mt-2 max-w-sm">
          Опитайте отново с друга дума или използвайте филтрите за бърз преглед.
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .filter-btn.active {
    background-color: #8c0e0e;
    color: #ffffff;
    border-color: #8c0e0e;
    box-shadow: 0 2px 8px rgba(140, 14, 14, 0.3);
  }
</style>

<script>
  const searchInput = document.getElementById("category-search") as HTMLInputElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>("#categories-grid a");
  const noResults = document.getElementById("no-results");

  let currentSearch = "";
  let currentGroup = "all";

  function filterCards() {
    let visibleCount = 0;

    cards.forEach((card) => {
      const title = card.getAttribute("data-title") || "";
      const subtitle = card.getAttribute("data-subtitle") || "";
      const group = card.getAttribute("data-group") || "";

      const matchesSearch =
        currentSearch === "" ||
        title.includes(currentSearch) ||
        subtitle.includes(currentSearch);
      const matchesGroup = currentGroup === "all" || group === currentGroup;

      if (matchesSearch && matchesGroup) {
        card.classList.remove("hidden");
        visibleCount++;
      } else {
        card.classList.add("hidden");
      }
    });

    if (visibleCount === 0) {
      noResults?.classList.remove("hidden");
      noResults?.classList.add("flex");
    } else {
      noResults?.classList.add("hidden");
      noResults?.classList.remove("flex");
    }
  }

  searchInput?.addEventListener("input", (e) => {
    currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
    filterCards();
  });

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      currentGroup = btn.getAttribute("data-filter") || "all";
      filterCards();
    });
  });
</script>